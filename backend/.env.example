# AshaKiran Backend - Environment Configuration Template
# Copy this file to '.env' and fill in your connection details.

# Database Host (MySQL / Aiven Cloud)
DB_HOST=your-database-host.aivencloud.com
DB_PORT=24154
DB_USER=avnadmin
DB_PASSWORD=your-secure-db-password
DB_NAME=defaultdb

# Flask Application Secret Key for JWT Signing
SECRET_KEY=your-production-secret-key-change-this

# Optional Allowed CORS Origins for production deployment
# Separate multiple origins with commas.
# ALLOWED_ORIGINS=https://ashakiran-ehr.com,https://dashboard.ashakiran-ehr.com
