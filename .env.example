# ── AshaKiran Docker Environment Configuration ──
# Copy this file to '.env' in the root folder before starting containers:
# cp docker.env.example .env

# Server Settings
FLASK_ENV=production
FLASK_DEBUG=false

# Security (CRITICAL: Replace these with strong random strings in production!)
SECRET_KEY=production-secret-key-change-me-in-production-12903741
JWT_SECRET_KEY=production-jwt-secret-key-change-me-in-production-47219830

# CORS Configuration
# Since Nginx acts as a reverse proxy, relative paths are used, bypassing CORS.
# For cross-origin mobile integrations (if applicable), set your domain here.
CORS_ORIGINS=*

# Host Port Mapping
# Port where the application frontend (Nginx) will be exposed on the host
PORT=80

# Database Configuration (PostgreSQL default)
DB_NAME=ashakiran
DB_USER=postgres
DB_PASSWORD=postgres_secure_pass_123
