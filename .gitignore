# ==============================================================================
# AshaKiran Unified Monorepo .gitignore
# ==============================================================================

# ── 1. Environment & Credentials (NEVER COMMIT SECRETS) ────────────────────────
.env
.env.*
!.env.example
docker.env
*.env
*.pem
*.key

# ── 2. Frontend / Node.js ─────────────────────────────────────────────────────
node_modules/
**/node_modules/
dist/
**/dist/
build/
**/build/
.svelte-kit/
.next/
.nuxt/
out/
.npm
*.tsbuildinfo

# ── 3. Backend / Python ───────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
*.egg
venv/
.venv/
env/
**/venv/
**/env/
**/.venv/

# ── 4. Databases & Persistent Storage ──────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
backend/instance/
**/instance/
instance/

# ── 5. User Uploads & Temporary Directories ───────────────────────────────────
backend/uploads/
**/uploads/
temp/
**/temp/
exports/
**/exports/

# ── 6. System & IDE Configuration ─────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── 7. Logging & Diagnostics ──────────────────────────────────────────────────
*.log
logs/
**/logs/
backend/backend_error.log

# ── 8. Test, Coverage & Build Caches ──────────────────────────────────────────
.pytest_cache/
**/ .pytest_cache/
.coverage
htmlcov/
.buildx-cache/
**/docker-cache/
